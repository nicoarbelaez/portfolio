{
  "name": "portfolio",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "dev": "concurrently \"astro dev\" \"pnpm dev:resume\" \"pnpm dev:resume-hash\"",
    "dev:resume": "python -m rendercv render ./resume/cv.yaml --watch --dont-generate-markdown --dont-generate-html --dont-generate-png --output-folder ./.tmp/rendercv --pdf-path ./resume.pdf",
    "dev:resume-hash": "chokidar \"resume/cv.yaml\" -c \"node ./resume/scripts/hash-resume.mjs\"",
    "build": "pnpm generate:resume && astro build",
    "generate:resume": "rendercv render ./resume/cv.yaml --dont-generate-markdown --dont-generate-html --dont-generate-png --output-folder ./.tmp/rendercv --pdf-path ./resume.pdf && node ./resume/scripts/hash-resume.mjs",
    "preview": "astro preview",
    "astro": "astro",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,astro}\"",
    "lint": "eslint \"**/*.{js,jsx,ts,tsx,astro}\"",
    "lint:fix": "eslint --fix \"**/*.{js,jsx,ts,tsx,astro}\"",
    "prepare": "husky"
  },
  "dependencies": {
    "@astrojs/react": "^5.0.5",
    "@astrojs/sitemap": "^3.7.2",
    "@astrojs/vercel": "^10.0.7",
    "@fontsource-variable/onest": "^5.2.8",
    "@formkit/tempo": "^0.1.2",
    "@js-temporal/polyfill": "^0.5.1",
    "@tabler/icons-react": "^3.36.1",
    "@tailwindcss/vite": "^4.1.6",
    "astro": "^6.3.7",
    "clsx": "^2.1.1",
    "puppeteer-core": "^24.15.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "tailwind-animations": "^1.0.1",
    "tailwind-merge": "^3.4.0",
    "tailwindcss": "^4.1.6"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@eslint/js": "^9.18.0",
    "@sparticuz/chromium": "^138.0.2",
    "@tailwindcss/typography": "^0.5.16",
    "@types/react": "^19.0.7",
    "@types/react-dom": "^19.0.3",
    "chokidar-cli": "^3.0.0",
    "concurrently": "^9.2.1",
    "eslint": "^9.18.0",
    "eslint-plugin-astro": "^1.3.1",
    "eslint-plugin-react": "^7.37.4",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-unused-imports": "^4.1.4",
    "globals": "^15.14.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.4.1",
    "prettier": "^3.5.3",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-tailwindcss": "^0.6.11",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.21.0"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,astro}": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.{json,md,css}": [
      "prettier --write"
    ]
  }
}
