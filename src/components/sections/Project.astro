---
import type { LocaleKey } from '@/i18n/ui';
import { getProjectsByLanguage, getImagePath, getRepoUrl } from '@/utils/projects';
import type { Transitions } from '@/i18n/utils';
import Section from '@/components/Section.astro';
import { getRepository } from '@/api/github/repository';
import { getUniqueTags, type ProjectTag, TAG_ORDER } from '@/types/project-tags';
import { ProjectTabs } from '@/components/ProjectTabs';
import { getTabTranslationKey } from '@/i18n/ui';

interface Props {
  lang: LocaleKey;
  t: Transitions;
}

const { lang, t } = Astro.props;

const translatedProjects = await getProjectsByLanguage(lang);

const projects = await Promise.all(
  translatedProjects.map(async ({ slug, data }) => {
    const repoUrl = getRepoUrl(data.repo_url, slug);
    const img = getImagePath(data.screenshot, slug);
    const dataRepo = repoUrl
      ? await getRepository('nicoarbelaez', repoUrl.split('/')[4]).catch(() => null)
      : null;
    return {
      ...data,
      img,
      slug,
      repo_url: repoUrl,
      github: dataRepo
    };
  })
).then((results) => results.sort((a, b) => b.priority - a.priority));

// Get unique tags across all projects (excluding 'other')
const projectTags: ProjectTag[] = getUniqueTags(
  translatedProjects.map((p) => p.data.tags as ProjectTag[] | undefined)
);
const hasUntaggedProjects = projects.some((p) => !p.tags || p.tags.length === 0);

// Add 'other' tag if there are untagged projects
let usedTags: ProjectTag[] = hasUntaggedProjects ? [...projectTags, 'other'] : projectTags;

// Sort tags according to defined order
usedTags.sort((a, b) => {
  const indexA = TAG_ORDER.indexOf(a);
  const indexB = TAG_ORDER.indexOf(b);
  return indexA - indexB;
});

// Group projects by tag
const projectsByTag: Record<string, typeof projects> = {};
for (const tag of projectTags) {
  projectsByTag[tag] = projects.filter((p) => p.tags?.includes(tag as any));
}

// Add untagged projects to 'other'
if (hasUntaggedProjects) {
  projectsByTag['other'] = projects.filter((p) => !p.tags || p.tags.length === 0);
}

// Default tab: first available tag
const defaultTab: ProjectTag = usedTags[0] || 'other';

// Prepare translated labels for tags (functions can't be serialized to client)
const tagLabels = TAG_ORDER.reduce(
  (acc, tag) => {
    acc[tag] = t(getTabTranslationKey(tag));
    return acc;
  },
  {} as Record<ProjectTag, string>
);

// Prepare translations for ProjectCard
const translations = {
  projectCode: t('project.code'),
  projectDemo: t('project.demo')
};
---

<Section id="projects" title={t('nav.projects')}>
  <ProjectTabs
    projectsByTag={projectsByTag}
    usedTags={usedTags}
    defaultTab={defaultTab}
    lang={lang}
    tagLabels={tagLabels}
    translations={translations}
    client:load
  />
</Section>
